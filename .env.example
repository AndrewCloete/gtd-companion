# Copy to .env and fill in your values.
# In Dokploy, set these as environment variables on the service instead.

# Web app → backend connection
GTD_SCHEME=http
GTD_WS_SCHEME=ws
GTD_BACKEND_PORT=10084

# Basic auth (used by gtd-cli when pushing tasks, and by the web app)
GTD_USER=
GTD_PSW=

# Protocol for click-to-open-in-editor (vscode, cursor, windsurf, zed...)
GTD_EDITOR_SCHEME=vscode
